# --- Dependencies (Bağımlılıklar) ---
# Node.js paketlerini tutan devasa klasör, asla pushlanmaz
node_modules/
jspm_packages/

# --- Build Outputs (Derleme Çıktıları) ---
# Vite projesini build ettiğinde oluşan klasör
dist/
dist-ssr/
*.local

# --- Environment Variables (Çevresel Değişkenler) ---
# Şifreler, API anahtarları (Sensitive data) burada tutulur, kesinlikle gizli kalmalı!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Editor & System Files (Editör ve Sistem Dosyaları) ---
.vscode/
.idea/
.DS_Store
thumbs.db
desktop.ini

# --- Test Results ---
/coverage
/.nyc_output

# --- Optional Backend (Eğer backend için farklı bir klasörün varsa) ---
# Örn: backend/venv/ veya backend/bin/